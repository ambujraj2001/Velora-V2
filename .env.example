# Platform database
# Local: use the Docker URL below
# Production: replace with your real Postgres URL
DATABASE_URL=postgresql://querymind:querymind@localhost:5432/querymind

# NVIDIA NIM — used for LLM and embeddings
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Security
SECRET_KEY=change-this-to-a-random-string
ENCRYPTION_KEY=change-this-to-a-valid-fernet-key

# Generate ENCRYPTION_KEY with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Logging (optional — ships structured JSON logs to Axiom when set)
AXIOM_TOKEN=
AXIOM_DATASET=velora
# AXIOM_ORG_ID=
LOG_LEVEL=INFO
APP_ENV=development
